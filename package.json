{
  "name": "resumeforge-ai",
  "version": "1.0.0",
  "description": "AI-powered resume tailoring platform with a visual WYSIWYG editor and real-time preview.",
  "private": true,
  "author": "Femi Sowemimo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/femisowems/resumeforge-ai"
  },
  "keywords": [
    "resume",
    "ai",
    "career",
    "gpt",
    "gemini",
    "anthropic",
    "deepseek",
    "builder",
    "nextjs",
    "nestjs",
    "tiptap"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run start:dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
